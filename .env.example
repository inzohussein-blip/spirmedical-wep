# ==========================================================
# Spir Medical · سباير ميديكال — Environment Variables
# ==========================================================
# انسخ هذا الملف لـ .env.local وعبّئ القيم الفعلية
# cp .env.example .env.local
#
# ⚠️ لا ترفع .env.local لـ GitHub أبداً (موجود في .gitignore)
# ==========================================================

# ─── Supabase Configuration ───
# من https://supabase.com/dashboard/project/ioulxemokusfeykjcaxg/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://ioulxemokusfeykjcaxg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️ مفتاح سرّي — على الخادم فقط، لا تكشفه أبداً
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App Configuration ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://spirmedical.iq

# ─── Optional: SMS Provider (للـ OTP) ───
# تكامل عبر Supabase Auth (Twilio/MessageBird)
# يُضبَط من Supabase Dashboard → Authentication → Providers → Phone

# ─── Optional: Sentry (Error Tracking) ───
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# ─── Optional: Analytics ───
# NEXT_PUBLIC_VERCEL_ANALYTICS=true
