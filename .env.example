# ==========================================================
# Spir Medical · سباير ميديكال — Environment Variables
# ==========================================================
# انسخ هذا الملف لـ .env.local وعبّئ القيم الفعلية
# cp .env.example .env.local
#
# ⚠️ لا ترفع .env.local لـ GitHub أبداً (موجود في .gitignore)
# ==========================================================

# ════════════════════════════════════════════════════════
# REQUIRED — لا يعمل التطبيق بدونها
# ════════════════════════════════════════════════════════

# ─── Supabase Configuration ───
# من https://supabase.com/dashboard/project/ioulxemokusfeykjcaxg/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://ioulxemokusfeykjcaxg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️ مفتاح سرّي — على الخادم فقط، لا تكشفه أبداً
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Encryption Key ───
# ⚠️ مفتاح تشفير AES-256-GCM للبيانات الطبية الحساسة
# لتوليد مفتاح جديد:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# يجب أن يكون 64 hex character (32 bytes)
# ⚠️ لا تغيّره بعد الإنتاج — البيانات المشفّرة لن تُفك!
ENCRYPTION_KEY=your-64-character-hex-key-here

# ─── App Configuration ───
NEXT_PUBLIC_SITE_URL=https://spirmedical.iq

# ════════════════════════════════════════════════════════
# SECURITY — المصادقة و OTP (مهم للإنتاج)
# ════════════════════════════════════════════════════════

# ─── OTP Mode ───
# required | optional | disabled  (الافتراضي الآمن: required)
# ⚠️ required يتطلب قناة OTP فعّالة (Meta WhatsApp أو Supabase SMS) قبل النشر،
#    وإلا تعذّر على المستخدمين تسجيل الدخول.
NEXT_PUBLIC_OTP_MODE=required

# ─── Passwordless Login (خطر — تطوير فقط) ───
# الدخول بدون رمز مسموح في وضع optional/disabled؛ يُقفَل نهائياً في وضع required.
# ALLOW_PASSWORDLESS_LOGIN=false

# ─── Auth Password Secret ───
# سرّ منفصل لاشتقاق كلمات سر حسابات الهاتف (يجب أن يختلف عن ENCRYPTION_KEY).
# توليد: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# عند ضبطه لأول مرة، يُحدَّث دخول المستخدمين الحاليين تلقائياً عند أول تسجيل.
# AUTH_PASSWORD_SECRET=your-separate-64-hex-secret

# ─── Meta WhatsApp Cloud API (لإرسال OTP الحقيقي) ───
# META_ACCESS_TOKEN=...
# META_PHONE_NUMBER_ID=...
# META_WEBHOOK_VERIFY_TOKEN=...
# WHATSAPP_PROVIDER=meta   # meta | twilio | mock (لا تستخدم mock في الإنتاج)

# ─── Admin ───
# مفتاح إنشاء حساب أدمن عبر النموذج (≥ 16 حرفاً؛ المفتاح وحده يُنشئ admin كحدّ أقصى)
# ADMIN_CREATE_KEY=...
# قائمة بريد مسموح لها بإنشاء أدمن (اختياري، مفصولة بفواصل)
# ADMIN_ALLOWED_EMAILS=owner@example.com
# بريد المالك لإشعارات طلبات الأدمن
# ADMIN_OWNER_EMAIL=owner@example.com

# ─── Resend (بريد التحقق/الإشعارات) ───
# RESEND_API_KEY=...
# RESEND_FROM_EMAIL=noreply@spir-medical.com

# ════════════════════════════════════════════════════════
# OPTIONAL — حسب الحاجة
# ════════════════════════════════════════════════════════

# ─── Logging ───
# debug | info | warn | error (default: production=info, dev=debug)
LOG_LEVEL=debug

# ─── Feature Flags ───
# للتحكم في تفعيل/تعطيل ميزات بدون redeploy
NEXT_PUBLIC_ENABLE_SPECIALIST_CHAT=false
NEXT_PUBLIC_ENABLE_FAMILY_ACCOUNTS=false
NEXT_PUBLIC_ENABLE_SUBSCRIPTIONS=false

# ─── Sentry (Error Tracking) ───
# 1. أنشئ مشروع على https://sentry.io
# 2. ضع DSN هنا
# 3. npm install @sentry/nextjs
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# SENTRY_AUTH_TOKEN=...

# ─── Upstash Redis (للـ rate limiting في الإنتاج) ───
# بديل للـ in-memory rate limit (لا يعمل عبر serverless instances)
# https://console.upstash.com
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# ─── Backup Configuration (للـ scripts/backup.sh) ───
# SUPABASE_DB_URL=postgresql://postgres:...@db.ioulxemokusfeykjcaxg.supabase.co:5432/postgres
# BACKUP_S3_BUCKET=spirmedical-backups
# BACKUP_DIR=/var/backups/spirmedical
# RETENTION_DAYS=30
