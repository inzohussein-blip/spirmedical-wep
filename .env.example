# ==========================================================
# Spir Medical · سباير ميديكال — Environment Variables
# ==========================================================
# انسخ هذا الملف لـ .env.local وعبّئ القيم الفعلية
# cp .env.example .env.local
#
# ⚠️ لا ترفع .env.local لـ GitHub أبداً (موجود في .gitignore)
# ==========================================================

# ─── Supabase Configuration ───
# من https://supabase.com/dashboard/project/ioulxemokusfeykjcaxg/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://ioulxemokusfeykjcaxg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️ مفتاح سرّي — على الخادم فقط، لا تكشفه أبداً
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App Configuration ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://spirmedical.iq

# ─── Encryption Key ───
# ⚠️ مفتاح تشفير AES-256-GCM للبيانات الطبية الحساسة
# لتوليد مفتاح جديد:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# يجب أن يكون 64 hex character (32 bytes)
# ⚠️ لا تغيّره بعد الإنتاج — البيانات المشفّرة لن تُفك!
ENCRYPTION_KEY=your-64-character-hex-key-here

# ─── Logging ───
# debug | info | warn | error
LOG_LEVEL=debug

# ─── Optional: Upstash Redis (للـ rate limiting في الإنتاج) ───
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ─── Optional: Sentry (Error Tracking) ───
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# ─── Optional: Analytics ───
# NEXT_PUBLIC_VERCEL_ANALYTICS=true
